{
  "extends": "@pancakeswap/tsconfig/base",
  "include": ["./src"],
  "exclude": ["**/*.test.ts", "./dist/**"],
  "compilerOptions": {
    "module": "esnext",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
