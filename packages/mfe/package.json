    "@pancakeswap/chains": "workspace:*",
    "styled-components": "*",
    "lodash": "*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.2.1",
    "vite": "5.0.12",
    "vite-plugin-dts": "^3.5.3",
